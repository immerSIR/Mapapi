# --- Model Deploy (AI service) ---
# IMPORTANT: routes are /analyze/upload and /chat (NO /api1 prefix). These MUST
# match on the backend AND the celery worker/beat (the worker runs the analyze
# task) — a mismatch (e.g. /api1/analyze/) makes every Prediction fail with 404.
MODEL_DEPLOY_ANALYZE_URL=https://model.map-action.com/analyze/upload
MODEL_DEPLOY_CHAT_URL=https://model.map-action.com/chat
MODEL_DEPLOY_TIMEOUT=180
MODEL_DEPLOY_CHAT_TIMEOUT=120